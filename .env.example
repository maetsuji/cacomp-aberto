# --- Tokens dos QR Codes estáticos (Seção 2.1 e 5.2 do SDD) ---
# Nunca são expostos ao frontend: só circulam na URL do QR impresso
# e são validados no servidor contra estas variáveis.
REPORT_TOKEN_EXTERNAL=troque-por-um-token-longo-e-aleatorio   # QR da porta (action=close)
REPORT_TOKEN_INTERNAL=troque-por-outro-token-longo-e-aleatorio # QR interno (action=open)

# --- Salt usado no hash anônimo de IP (rate limiting, Seção 5.1) ---
IP_HASH_SALT=um-salt-secreto-qualquer

# --- Redis na Vercel ---
# O app aceita KV_REST_*, UPSTASH_REDIS_REST_* ou apenas REDIS_URL.
# Dev local: `docker compose up -d` e use REDIS_URL=redis://localhost:6379
# (sem nenhum store configurado, nada persiste — ver docs/DEV.md).
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# --- GIF de status (Home) ---
# Chave gratuita em https://developers.giphy.com (plano Basic).
# Sem essa variável, a Home simplesmente não exibe o GIF — não quebra o build.
GIPHY_API_KEY=

# --- Crons (vercel.json: auto-close 00h e rotate-tokens 06h) ---
# A Vercel injeta "Authorization: Bearer $CRON_SECRET" automaticamente ao
# disparar o cron. Sem essa variável, os endpoints ficam bloqueados (401).
CRON_SECRET=troque-por-um-segredo-longo-e-aleatorio

# --- Página /admin (tela de login própria, sessão de 12h) ---
# Sem ADMIN_PASSWORD, o /admin (e a própria tela de login) responde 503 —
# fechado por padrão.
ADMIN_USER=admin
ADMIN_PASSWORD=troque-por-uma-senha-forte

# --- Short links short.io (QRs impressos apontam para eles; rotação de
#     token atualiza o destino sem regenerar a imagem) ---
# SHORTIO_API_KEY: secret key da conta (enviada crua no header Authorization).
# SHORTIO_DOMAIN: domínio único de encurtamento; os dois links fixos são
# criados nele com paths determinísticos /open e /close.
SHORTIO_API_KEY=
SHORTIO_DOMAIN=report.cacomp.xyz
# SHORTIO_API_BASE=https://api.short.io

# --- URL pública de produção (destino dos short links) ---
SITE_URL=https://cacomp.xyz

# --- Circuit breaker diário + anti-flood (protege a cota gratuita do Redis) ---
# Janela rolante de 24h desde o primeiro request — não reseta à meia-noite.
REPORT_DAILY_CAP=500
REPORT_IP_FLOOD_CAP=20

# --- Geofence por GPS (liga/desliga pelo botão no /admin; aqui só as
#     coordenadas). Mitiga o problema do link/QR/NFC estável — rotacionar
#     token não impede alguém de reportar de qualquer lugar com o link
#     compartilhado, só uma prova de proximidade ajuda. É um dissuasor de
#     compartilhamento casual, não uma prova inquebrável (ver README). ---
# Coordenadas do CA (pegue no Google Maps) e raio de tolerância em metros.
GEOFENCE_LAT=
GEOFENCE_LNG=
GEOFENCE_RADIUS_METERS=150
